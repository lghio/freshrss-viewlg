					$isEnabled    = $savedColor !== '';
					$pickerValue  = $isEnabled ? $savedColor : '#fffde7';
				?>
					<tr>
						<td class="cv-td-check">
							<input type="checkbox"
							       id="cv_enable_<?php echo $feedId; ?>"
							       name="cv_color_enabled[<?php echo $feedId; ?>]"
