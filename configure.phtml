					       id="cv_hex_<?php echo $feedId; ?>"
					       class="cv-hex-input"
					       value="<?php echo $pickerValue; ?>"
					       data-feed-id="<?php echo $feedId; ?>"
					       maxlength="7"
					       pattern="#[0-9a-fA-F]{6}"
					       placeholder="#rrggbb">						</td>
						<td>
							<span class="cv-preview"
							      id="cv_preview_<?php echo $feedId; ?>"
							      <?php if ($isEnabled): ?>data-color="<?php echo $savedColor; ?>"<?php endif; ?>>
