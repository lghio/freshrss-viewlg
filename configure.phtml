							       data-feed-id="<?php echo $feedId; ?>"
							       <?php echo $isEnabled ? 'checked="checked"' : ''; ?>>
						</td>
						<td>
							<label for="cv_enable_<?php echo $feedId; ?>" class="cv-feed-name">
