			<p>Aucun flux trouvé. Abonnez-vous à au moins un flux pour voir la liste.</p>
		<?php else : ?>
		<div class="cv-table-wrapper">
			<table class="cv-table">
				<thead>
					<tr>
						<th>Activer</th>
						<th>Flux</th>
